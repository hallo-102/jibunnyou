KEIBA_APP_NAME=Keiba AI Studio
KEIBA_APP_VERSION=1.0.0
KEIBA_ENVIRONMENT=local
KEIBA_APP_PORT=18080
KEIBA_GIT_COMMIT=unknown
KEIBA_FRONTEND_API_BASE_URL=/api

KEIBA_POSTGRES_DB=keiba_ai_studio
KEIBA_POSTGRES_USER=keiba_app
KEIBA_POSTGRES_PASSWORD=CHANGE_THIS_TO_A_LONG_RANDOM_PASSWORD
KEIBA_DATABASE_URL=postgresql+psycopg2://keiba_app:CHANGE_THIS_TO_A_LONG_RANDOM_PASSWORD@postgres:5432/keiba_ai_studio
KEIBA_REDIS_URL=redis://redis:6379/0

KEIBA_DATA_ROOT=/workspace/data
KEIBA_EXCEL_INPUT_DIR=/workspace/data/raw/excel
KEIBA_ODDS_INPUT_DIR=/workspace/data/raw/odds
KEIBA_LEGACY_OUTPUT_DIR=/workspace/data/raw/legacy_output
KEIBA_RAW_SNAPSHOTS_DIR=/workspace/data/raw_snapshots
KEIBA_NORMALIZED_DIR=/workspace/data/normalized
KEIBA_SNAPSHOTS_DIR=/workspace/data/snapshots
KEIBA_STAGING_DIR=/workspace/data/staging
KEIBA_EXPORTS_DIR=/workspace/data/exports
KEIBA_LOGS_DIR=/workspace/data/logs
KEIBA_LEGACY_ROOT=/workspace/legacy
KEIBA_LEGACY_RUNNER_MODE=dry_run
KEIBA_LEGACY_TIMEOUT_SECONDS=900
KEIBA_PREDICTION_RUNNER_MODE=dry_run
KEIBA_PREDICTION_TIMEOUT_SECONDS=1800

# OpenAI APIキーはリポジトリへ保存せず、ローカルの.envまたは秘密管理機能で設定する。
OPENAI_API_KEY=
KEIBA_AI_PROVIDER=openai
KEIBA_AI_MODEL=gpt-5.4-mini-2026-03-17
KEIBA_AI_REASONING_EFFORT=low
KEIBA_AI_TIMEOUT_SECONDS=120
KEIBA_AI_MAX_OUTPUT_TOKENS=8000
KEIBA_AI_MAX_RETRIES=2
KEIBA_AI_RETRY_DELAYS_SECONDS=[2,10]

KEIBA_COLLECTOR_MAX_RETRIES=3
KEIBA_COLLECTOR_RETRY_DELAYS_SECONDS=[10,60,300]
KEIBA_COLLECTOR_MIN_INTERVAL_SECONDS=60
KEIBA_JOB_EXECUTION_MODE=queue
KEIBA_ODDS_FRESHNESS_WARNING_MINUTES=30
KEIBA_ODDS_FRESHNESS_CRITICAL_MINUTES=120
KEIBA_COLLECTOR_APPROVED_SOURCES=[]
KEIBA_CORS_ORIGINS=["http://localhost:18080","http://127.0.0.1:18080"]
